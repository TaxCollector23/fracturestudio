{
  "buildCommand": "node -e \"console.log('No build step needed for Fracture Studio static app')\"",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/studio",
      "destination": "/studio.html"
    },
    {
      "source": "/studio/case",
      "destination": "/studio.html"
    },
    {
      "source": "/analyze",
      "destination": "/studio.html"
    },
    {
      "source": "/mission",
      "destination": "/mission.html"
    },
    {
      "source": "/methods",
      "destination": "/mission.html"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/credits",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    },
    {
      "source": "/onboarding",
      "destination": "/index.html"
    },
    {
      "source": "/past-work",
      "destination": "/past-work.html"
    },
    {
      "source": "/rebuttals",
      "destination": "/rebuttals.html"
    },
    {
      "source": "/settings",
      "destination": "/settings.html"
    },
    {
      "source": "/login",
      "destination": "/settings.html"
    },
    {
      "source": "/auth/callback",
      "destination": "/auth-callback.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/studio/(.*)",
      "destination": "/$1"
    }
  ]
}
