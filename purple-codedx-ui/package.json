{
  "name": "fracture-studio",
  "version": "2.0.0",
  "description": "Fracture Studio — AI-powered surgical argument analysis engine",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "pocketbase:start": ".\\.tools\\pocketbase\\pocketbase.exe serve --dir=pb_data --migrationsDir=pb_migrations",
    "pocketbase:migrate": ".\\.tools\\pocketbase\\pocketbase.exe migrate up --dir=pb_data --migrationsDir=pb_migrations"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pocketbase": "^0.27.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
