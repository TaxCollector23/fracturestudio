# Required for any environment that runs POST /api/chat (local Vite middleware, Netlify, Vercel, Cloudflare).
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: when the static UI is served from a different origin than the API,
# set this to the API site's origin (no trailing slash). Example: https://my-app.netlify.app
# Leave unset for same-origin /api/chat (Netlify, Vercel, Cloudflare full-stack, local dev).
# VITE_CHAT_API_BASE=https://your-api-host.example
