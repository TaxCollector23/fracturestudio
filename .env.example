# Fracture Studio environment variables
# Copy this file to .env and fill in secret values. Never commit .env.

# AI analysis service
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b
# Optional: override the model used by Fracture Chat.
OPENROUTER_CHAT_MODEL=openai/gpt-oss-120b
# Optional: fast live-debate model used by Speed Rebuttals.
OPENROUTER_SPEED_MODEL=openai/gpt-oss-120b
SITE_URL=http://127.0.0.1:8000
PORT=8000

# Hosted authentication and saved-work storage
# Firebase web configuration is public; Firestore rules protect user data.
PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
PUBLIC_FIREBASE_APP_ID=your_web_app_id

# Private admin page
# Generate a Firebase service-account key and place its complete JSON object on
# one line as the value. Never expose this value to browser code or commit it.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}
# Required for the private account administration page.
FRACTURE_ADMIN_PASSWORD=replace-with-a-long-private-password
